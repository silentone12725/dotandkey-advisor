# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: "nim" | "ollama" | "openai" | "google"
LLM_PROVIDER=nim

# NIM (dev/testing — Qwen3.5-122B-A10B)
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=qwen/qwen3.5-122b-a10b

# Ollama (local fallback — Qwen3.5-4B)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5:4b

# OpenAI-compatible fallback
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Gemini fallback
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxx
GOOGLE_MODEL=gemini-2.0-flash

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── FalkorDB ─────────────────────────────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=dotandkey

# ── Weather ───────────────────────────────────────────────────────────────────
TOMORROW_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ── Backend ───────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
# In prod: https://www.dotandkey.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://www.dotandkey.com

# Token budget per LLM call
MAX_INPUT_TOKENS=2000
MAX_OUTPUT_TOKENS=300

# Profile TTL in seconds: 60 days
PROFILE_TTL_SECONDS=5184000

# Session TTL in seconds: 30 minutes
SESSION_TTL_SECONDS=1800

# History TTL in seconds: 365 days
HISTORY_TTL_SECONDS=31536000
